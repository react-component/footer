{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "lib": [
      "dom",
      "es2017"
    ],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": [
      "jest",
      "node"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@@/*": [
        ".dumi/tmp/*"
      ],
      "@rc-component/footer": [
        "src/index.tsx"
      ],
      "@rc-component/footer/assets": [
        "assets"
      ],
      "@rc-component/footer/assets/*": [
        "assets/*"
      ],
      "@rc-component/footer/*": [
        "src/*"
      ],
      "rc-footer": [
        "src/index.tsx"
      ]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    ".dumirc.ts",
    "src",
    "tests",
    "docs/examples",
    "type.d.ts"
  ],
  "exclude": [
    "docs-dist",
    "lib",
    "es"
  ]
}
